{
  "name": "Zsh (Minimal)",
  "scopeName": "source.zsh",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#variables" },
    { "include": "#keywords" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.zsh", "match": "#.*$" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.zsh", "begin": "\"", "end": "\"", "patterns": [ { "match": "\\\\.", "name": "constant.character.escape.zsh" } ] },
        { "name": "string.quoted.single.zsh", "begin": "'", "end": "'" }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.other.zsh", "match": "\\$\\{?[A-Za-z_][A-Za-z0-9_]*\\}?" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.zsh", "match": "\\b(if|then|else|elif|fi|for|while|do|done|case|esac|in|function|select|until|time)\\b" },
        { "name": "support.function.zsh", "match": "\\b(echo|printf|cd|pwd|exit|export|unset|alias|source|test|true|false|typeset|autoload|setopt|unsetopt)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.zsh", "match": "\\b\\d+(?:\\.\\d+)?\\b" }
      ]
    }
  }
}
