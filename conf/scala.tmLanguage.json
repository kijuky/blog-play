{
  "scopeName": "source.scala",
  "name": "Scala (Minimal)",
  "patterns": [
    {
      "name": "comment.line.double-slash.scala",
      "match": "//.*$"
    },
    {
      "name": "comment.block.scala",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "string.quoted.triple.scala",
      "begin": "\"\"\"",
      "end": "\"\"\""
    },
    {
      "name": "string.quoted.double.scala",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.scala",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "identifier.escaped.scala",
      "match": "`[^`]+`"
    },
    {
      "name": "keyword.control.scala",
      "match": "\\b(as|case|catch|class|def|do|else|enum|extends|export|final|finally|for|forSome|given|if|implicit|import|infix|inline|lazy|macro|match|new|object|opaque|open|override|package|private|protected|return|sealed|super|then|this|throw|trait|try|type|using|val|var|while|with|yield)\\b"
    },
    {
      "name": "keyword.other.scala",
      "match": "\\b(abstract|derives|end|extension|transparent)\\b"
    },
    {
      "name": "constant.numeric.scala",
      "match": "\\b\\d+(?:\\.\\d+)?\\b"
    }
  ]
}
