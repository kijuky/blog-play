{
  "name": "Go (Minimal)",
  "scopeName": "source.go",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.go", "match": "//.*$" },
        { "name": "comment.block.go", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.go", "begin": "\"", "end": "\"", "patterns": [ { "match": "\\\\.", "name": "constant.character.escape.go" } ] },
        { "name": "string.quoted.raw.go", "begin": "`", "end": "`" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.go", "match": "\\b(package|import|func|return|if|else|for|range|switch|case|default|break|continue|defer|go|select|struct|interface|map|chan|var|const|type)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.go", "match": "\\b\\d+(?:\\.\\d+)?\\b" }
      ]
    }
  }
}
