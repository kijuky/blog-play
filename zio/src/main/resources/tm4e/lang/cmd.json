{
  "name": "Batch (Minimal)",
  "scopeName": "source.cmd",
  "fileTypes": ["cmd", "bat"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#variables" },
    { "include": "#keywords" },
    { "include": "#labels" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.rem.batch", "match": "^\\s*rem\\b.*$" },
        { "name": "comment.line.double-colon.batch", "match": "^\\s*::.*$" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.batch", "begin": "\"", "end": "\"" }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.other.batch", "match": "%[A-Za-z0-9_]+%" },
        { "name": "variable.other.batch", "match": "![A-Za-z0-9_]+!" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.batch", "match": "\\b(if|else|for|in|do|goto|call|exit|set|setlocal|endlocal|enabledelayedexpansion|disabledelayedexpansion|shift|pause|choice)\\b" },
        { "name": "support.function.batch", "match": "\\b(echo|type|dir|copy|move|del|ren|mkdir|rmdir|pushd|popd)\\b" }
      ]
    },
    "labels": {
      "patterns": [
        { "name": "entity.name.label.batch", "match": "^\\s*:[A-Za-z0-9_]+\\b" }
      ]
    }
  }
}
