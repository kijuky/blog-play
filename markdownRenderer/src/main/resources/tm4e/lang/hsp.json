{
  "name": "HSP (Minimal)",
  "scopeName": "source.hsp",
  "fileTypes": ["hsp"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.semicolon.hsp", "match": ";.*$" },
        { "name": "comment.line.number-sign.hsp", "match": "#.*$" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.hsp", "begin": "\"", "end": "\"", "patterns": [ { "match": "\\\\.", "name": "constant.character.escape.hsp" } ] }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.hsp", "match": "\\b(if|else|elseif|endif|for|next|repeat|loop|break|continue|return)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hsp", "match": "\\b\\d+(?:\\.\\d+)?\\b" }
      ]
    }
  }
}
