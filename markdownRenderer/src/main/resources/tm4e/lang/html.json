{
  "name": "HTML (Minimal)",
  "scopeName": "text.html",
  "fileTypes": ["html", "htm"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#tags" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.block.html", "begin": "<!--", "end": "-->" }
      ]
    },
    "tags": {
      "patterns": [
        { "name": "meta.tag.html", "match": "</?[A-Za-z_][A-Za-z0-9_\\-\\.]*" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.html", "begin": "\"", "end": "\"" },
        { "name": "string.quoted.single.html", "begin": "'", "end": "'" }
      ]
    }
  }
}
