# Play secret key (required).
# Recommended: generate a strong one:
#   openssl rand -hex 32
PLAY_HTTP_SECRET_KEY=changeme

# Host port to bind (default: 9000).
#PORT=9000

# Allowed host pattern (default: .).
#HOST=.

# JDBC URL (default is H2 in PostgreSQL mode).
# You can override this to another JDBC URL as needed (e.g. H2 memory, PostgreSQL).
#BLOG_DB_DRIVER=org.h2.Driver
#BLOG_DB_URL=jdbc:h2:file:./data/blog;MODE=PostgreSQL
#BLOG_DB_URL=jdbc:h2:mem:blog;MODE=PostgreSQL;DB_CLOSE_DELAY=-1
