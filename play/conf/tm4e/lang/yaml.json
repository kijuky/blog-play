{
  "name": "YAML (Minimal)",
  "scopeName": "source.yaml",
  "fileTypes": ["yaml", "yml"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keys" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.yaml", "match": "#.*$" }
      ]
    },
    "keys": {
      "patterns": [
        { "name": "entity.name.tag.yaml", "match": "^\\s*[A-Za-z0-9_\\-\\.]+(?=\\s*:)" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.yaml", "begin": "\"", "end": "\"", "patterns": [ { "match": "\\\\.", "name": "constant.character.escape.yaml" } ] },
        { "name": "string.quoted.single.yaml", "begin": "'", "end": "'" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.yaml", "match": "-?\\b\\d+(?:\\.\\d+)?\\b" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.yaml", "match": "\\b(true|false|null)\\b" }
      ]
    }
  }
}
