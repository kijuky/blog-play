{
  "name": "Dockerfile (Minimal)",
  "scopeName": "source.dockerfile",
  "fileTypes": ["dockerfile"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#instructions" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.dockerfile", "match": "#.*$" }
      ]
    },
    "instructions": {
      "patterns": [
        { "name": "keyword.control.dockerfile", "match": "^(?i)(FROM|RUN|CMD|LABEL|MAINTAINER|EXPOSE|ENV|ADD|COPY|ENTRYPOINT|VOLUME|USER|WORKDIR|ARG|ONBUILD|STOPSIGNAL|HEALTHCHECK)\\b" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.dockerfile", "begin": "\"", "end": "\"", "patterns": [ { "match": "\\\\.", "name": "constant.character.escape.dockerfile" } ] },
        { "name": "string.quoted.single.dockerfile", "begin": "'", "end": "'" }
      ]
    }
  }
}
